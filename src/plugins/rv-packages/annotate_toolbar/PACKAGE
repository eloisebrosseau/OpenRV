package: Annotate Toolbar
author: Autodesk, Inc.
organization: Autodesk, Inc.
version: 0.1
rv: 2025.1
openrv: 3.0.0
optional: true
hidden: false
excludes: annotate

modes:
  - file: annotate_toolbar_mode.py
    load: immediate

description: |
  <p>New Python-based annotation toolbar matching the FY27 design.
  Provides shapes (rectangle, ellipse, arrow, line) and text annotation tools
  in addition to brush and eraser tools.</p>

  <p>This package is experimental and disabled by default in favor of the
  legacy "Annotation" package. The two cannot run at the same time, so
  enabling this package automatically disables "Annotation".</p>
